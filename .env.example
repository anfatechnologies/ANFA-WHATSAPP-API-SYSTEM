# /.env.example
# ANFA WhatsApp Platform - Environment Configuration Template
# Copy this file to .env and fill in your actual values before running docker compose up -d

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Set to false in production
DEBUG=false
# Your deployed frontend URL — required for production CORS (e.g. https://crm.yourdomain.com)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_PASSWORD=your_secure_random_postgres_password_here_change_me_immediately

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PASSWORD=your_secure_random_redis_password_here_change_me_immediately

# =============================================================================
# META CLOUD API CREDENTIALS
# =============================================================================
# Your WhatsApp Business Account credentials from Meta Developer Console
# NEVER commit these to version control
WHATSAPP_ACCESS_TOKEN=your_meta_cloud_api_permanent_access_token
WHATSAPP_APP_SECRET=your_meta_webhook_app_secret_for_signature_verification
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token_for_subscription

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate a strong random secret key for JWT token signing
SECRET_KEY=your_256_bit_secret_key_for_jwt_signing_use_openssl_rand_base64_32
# Algorithm used for JWT encoding
ALGORITHM=HS256
# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
# AES-256-GCM key used to encrypt sensitive data at rest (Meta access tokens,
# app secrets, message bodies). REQUIRED - generate your own, never reuse an
# example value. Generate with: openssl rand -hex 16
ENCRYPTION_MASTER_KEY=your_own_generated_32_char_encryption_key_change_me

# =============================================================================
# ADMIN ACCOUNT (dashboard login)
# =============================================================================
# This project currently uses a single shared admin account rather than
# per-user login. REQUIRED - both must be set or the backend will refuse to
# start.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_unique_password

# =============================================================================
# N8N AUTOMATION INTEGRATION (OPTIONAL)
# =============================================================================
# Set this to your n8n Webhook Trigger node URL to enable automation workflows.
# When set, every inbound WhatsApp message will be dispatched to n8n in real-time.
# Example: http://n8n:5678/webhook/your-unique-webhook-id
# Leave blank to disable n8n integration.
N8N_WEBHOOK_URL=
# Master switch to enable/disable n8n dispatching (true/false)
N8N_ENABLED=true
